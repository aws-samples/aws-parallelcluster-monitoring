      "targets": [
        {
          "refId": "A",
          "expr": "((1 - avg by(instance_id) (rate(node_cpu_seconds_total{mode=\"idle\",instance_name=\"RES\"}[1m]))) * 100) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"RES\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "B",
          "expr": "((1 - (node_memory_MemAvailable_bytes{instance_name=\"RES\"} / node_memory_MemTotal_bytes{instance_name=\"RES\"})) * 100) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"RES\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "C",
          "expr": "((1 - (node_filesystem_avail_bytes{instance_name=\"RES\",mountpoint=\"/\",fstype=~\"ext4|xfs\"} / node_filesystem_size_bytes{instance_name=\"RES\",mountpoint=\"/\",fstype=~\"ext4|xfs\"})) * 100) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"RES\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "D",
          "expr": "(node_load1{instance_name=\"RES\"} / count by(instance_id) (node_cpu_seconds_total{instance_name=\"RES\",mode=\"idle\"})) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"RES\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "E",
          "expr": "(sum by(instance_id) (rate(node_network_receive_bytes_total{instance_name=\"RES\",device!~\"tap.*|veth.*|br.*|docker.*|virbr.*|lo.*\"}[1m]) + rate(node_network_transmit_bytes_total{instance_name=\"RES\",device!~\"tap.*|veth.*|br.*|docker.*|virbr.*|lo.*\"}[1m]))) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"RES\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "F",
          "expr": "((time() - node_boot_time_seconds{instance_name=\"RES\"})) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"RES\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "G",
          "expr": "node_uname_info{instance_name=\"RES\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "H",
          "expr": "avg by(instance_id) (DCGM_FI_DEV_GPU_UTIL{instance_name=\"RES\"}) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"RES\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
