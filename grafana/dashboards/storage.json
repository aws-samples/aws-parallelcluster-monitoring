    "fsx",
    "efs"
  ],
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "refresh": "1m",
  "links": [
    {
      "title": "Cluster Summary",
      "url": "/grafana/d/r9_U2AzGz/cluster-summary",
      "type": "link",
      "icon": "dashboard",
      "targetBlank": false
    },
    {
      "title": "Slurm Detail",
      "url": "/grafana/d/slurm-detail/slurm-detail",
      "type": "link",
      "icon": "dashboard",
