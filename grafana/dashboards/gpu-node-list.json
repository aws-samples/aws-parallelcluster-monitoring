{
  "uid": "gpu-node-list",
  "title": "GPU Node List",
  "schemaVersion": 39,
  "editable": true,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "table",
      "title": "GPU Nodes",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": "prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "avg by(instance_id, instance_type, modelName) (DCGM_FI_DEV_GPU_UTIL)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "avg by(instance_id) (DCGM_FI_DEV_GPU_TEMP)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "avg by(instance_id) (DCGM_FI_DEV_POWER_USAGE)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "avg by(instance_id) (DCGM_FI_DEV_FB_USED / (DCGM_FI_DEV_FB_USED + DCGM_FI_DEV_FB_FREE) * 100)",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          },
          "links": [
            {
              "title": "View GPU node details",
              "url": "/d/hpcsyl6zhqk/?var-gpu_node=${__data.fields.instance_id}",
              "targetBlank": false
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "GPU Util %"
              },
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 100
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 70
                    },
                    {
                      "color": "red",
                      "value": 90
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #B"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Temp \u00b0C"
              },
              {
                "id": "unit",
                "value": "celsius"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 70
                    },
                    {
                      "color": "red",
                      "value": 85
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #C"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Power W"
              },
              {
                "id": "unit",
                "value": "watt"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #D"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Mem %"
              },
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 100
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient"
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "modelName": "GPU Model",
              "instance_id": "Instance ID",
              "instance_type": "Instance Type",
              "Value #A": "GPU Util %",
              "Value #B": "Temp \u00b0C",
              "Value #C": "Power W",
              "Value #D": "Mem %"
            },
            "indexByName": {
              "modelName": 0,
              "instance_type": 1,
              "instance_id": 2,
              "Value #A": 3,
              "Value #B": 4,
              "Value #C": 5,
              "Value #D": 6
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "GPU Util %",
            "desc": true
          }
        ]
      }
    }
  ]
}