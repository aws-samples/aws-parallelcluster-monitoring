        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "type": "timeseries",
      "title": "PCIe replay counter (retries/sec)",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 56
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(DCGM_FI_DEV_PCIE_REPLAY_COUNTER[5m])",
          "legendFormat": "{{instance_id}} GPU{{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
