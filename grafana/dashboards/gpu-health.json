    },
    {
      "type": "timeseries",
      "title": "NVLink Recovery + Replay errors (rate)",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 49
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(DCGM_FI_DEV_NVLINK_RECOVERY_ERROR_COUNT_TOTAL[5m])",
          "legendFormat": "{{instance_id}} GPU{{gpu}} recovery"
        },
        {
          "refId": "B",
          "expr": "rate(DCGM_FI_DEV_NVLINK_REPLAY_ERROR_COUNT_TOTAL[5m])",
