      "targets": [
        {
          "refId": "A",
          "expr": "((1 - avg by(instance_id) (rate(node_cpu_seconds_total{mode=\"idle\",instance_name=\"Compute\"}[1m]))) * 100) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"Compute\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "B",
          "expr": "((1 - (node_memory_MemAvailable_bytes{instance_name=\"Compute\"} / node_memory_MemTotal_bytes{instance_name=\"Compute\"})) * 100) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"Compute\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "C",
          "expr": "((1 - (node_filesystem_avail_bytes{instance_name=\"Compute\",mountpoint=\"/\",fstype=~\"ext4|xfs\"} / node_filesystem_size_bytes{instance_name=\"Compute\",mountpoint=\"/\",fstype=~\"ext4|xfs\"})) * 100) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"Compute\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "D",
          "expr": "(node_load1{instance_name=\"Compute\"} / count by(instance_id) (node_cpu_seconds_total{instance_name=\"Compute\",mode=\"idle\"})) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"Compute\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "E",
          "expr": "(sum by(instance_id) (rate(node_network_receive_bytes_total{instance_name=\"Compute\",device!~\"tap.*|veth.*|br.*|docker.*|virbr.*|lo.*\"}[1m]) + rate(node_network_transmit_bytes_total{instance_name=\"Compute\",device!~\"tap.*|veth.*|br.*|docker.*|virbr.*|lo.*\"}[1m]))) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"Compute\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "F",
          "expr": "((time() - node_boot_time_seconds{instance_name=\"Compute\"})) * on(instance_id) group_left(nodename, instance_type) node_uname_info{instance_name=\"Compute\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "G",
          "expr": "node_uname_info{instance_name=\"Compute\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "refId": "H",
          "expr": "slurm_job_node * on(nodename) group_left(instance_id) node_uname_info{instance_name=\"Compute\"}",
          "format": "table",
          "instant": true
        }
      ],
