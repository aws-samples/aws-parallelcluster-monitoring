    },
    {
      "type": "table",
      "title": "Account Quota Utilization",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "datasource": "prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "slurm_account_cpu_limit",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "sum by(account) (slurm_account_job_state_cpu_alloc{state=~\"alloc|mix\"})",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "slurm_account_mem_limit",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "sum by(account) (slurm_account_job_state_mem_alloc{state=~\"alloc|mix\"})",
          "format": "table",
          "instant": true
        },
        {
          "refId": "E",
          "expr": "slurm_account_job_limit",
          "format": "table",
          "instant": true
        },
        {
          "refId": "F",
          "expr": "sum by(account) (slurm_account_job_state_total{state=~\"running|pending\"})",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*\\(B\\)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "CPU Used",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "account": "Account",
              "Value #A": "CPU Limit",
              "Value #B": "CPU Used",
              "Value #C": "Mem Limit (B)",
              "Value #D": "Mem Used (B)",
              "Value #E": "Job Limit",
              "Value #F": "Jobs Used"
            },
            "indexByName": {
              "account": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4,
              "Value #E": 5,
              "Value #F": 6
            }
          }
        }
      ]
    },
