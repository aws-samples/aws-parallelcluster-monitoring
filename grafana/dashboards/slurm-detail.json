    {
      "type": "row",
      "title": "Top Users & Accounts",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "table",
      "title": "Top Users (by allocated CPUs)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 25
      },
      "datasource": "prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(username) (slurm_user_cpu_alloc{state=~\"alloc|mix\"})",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "sum by(username) (slurm_user_mem_alloc{state=~\"alloc|mix\"})",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "sum by(username) (slurm_user_state_total{state=\"running\"})",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "sum by(username) (slurm_user_state_total{state=\"pending\"})",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Mem Alloc (B)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "CPUs Alloc",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "username": "User",
              "Value #A": "CPUs Alloc",
              "Value #B": "Mem Alloc (B)",
              "Value #C": "Jobs Running",
              "Value #D": "Jobs Pending"
            },
            "indexByName": {
              "username": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4
            }
          }
        }
      ]
    },
    {
      "type": "table",
      "title": "Top Accounts (by allocated CPUs)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
