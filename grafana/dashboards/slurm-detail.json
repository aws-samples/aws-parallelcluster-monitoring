    {
      "type": "table",
      "title": "Top RPC Message Types (avg time)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 59
      },
      "datasource": "prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "topk(15, slurm_rpc_msg_type_avg_time)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "topk(15, slurm_rpc_msg_type_count)",
