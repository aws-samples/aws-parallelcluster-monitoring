              }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
