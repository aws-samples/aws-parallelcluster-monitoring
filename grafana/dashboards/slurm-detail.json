{
  "uid": "slurm-detail",
  "title": "Slurm Detail",
  "schemaVersion": 39,
  "editable": true,
  "tags": [
    "slurm",
    "scheduler"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "refresh": "30s",
  "panels": [
    {
      "type": "row",
      "title": "Partition Health",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "table",
      "title": "Partitions",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "datasource": "prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(partition) (slurm_partition_node_count) - sum by(partition) (slurm_partition_node_count{state=~\"idle.*\"}) - sum by(partition) (slurm_partition_node_count{state=~\"down.*|drain.*\"}) or sum by(partition) (slurm_partition_node_count) * 0",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "sum by(partition) (slurm_partition_node_count{state=~\"idle.*\"})",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "sum by(partition) (slurm_partition_node_count{state=~\"down.*|drain.*\"})",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "sum by(partition) (slurm_partition_alloc_cpus)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "E",
          "expr": "slurm_partition_idle_cpus",
          "format": "table",
          "instant": true
        },
        {
          "refId": "F",
          "expr": "slurm_partition_cpu_load",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Nodes Down/Drain"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "CPU Load"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "CPUs Alloc",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "partition": "Partition",
              "Value #A": "Nodes Busy",
              "Value #B": "Nodes Idle",
              "Value #C": "Nodes Down/Drain",
              "Value #D": "CPUs Alloc",
              "Value #E": "CPUs Idle",
              "Value #F": "CPU Load"
            },
            "indexByName": {
              "partition": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4,
              "Value #E": 5,
              "Value #F": 6
            }
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Queue Health",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Pending Jobs by Reason",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(reason) (slurm_pending_reason_total)",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "type": "bargauge",
      "title": "Top Pending Reasons (now)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by(reason) (slurm_pending_reason_total))",
          "legendFormat": "{{reason}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Pending Now",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(slurm_jobs_pending) or vector(0)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Running Now",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(slurm_jobs_running) or vector(0)",
